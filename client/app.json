{
  "expo": {
    "sdkVersion": "55.0.0",
    "name": "Careerality",
    "slug": "Careerality",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#101010",
      "dark": {
        "backgroundColor": "#101010"
      }
    },
    "ios": {
      "bundleIdentifier": "app.careerality.app",
      "buildNumber": "1",
      "supportsTablet": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#101010",
        "foregroundImage": "./assets/adaptive-icon.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "app.careerality.app",
      "versionCode": 1,
      "permissions": []
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "1f9cb470-a9c4-44d7-aa40-4f6e3f02641d"
      }
    }
  }
}
